server {
    listen 443 default_server;
    listen [::]:443 default_server;
    
    root /var/www/html;
    index index.html;
    
    server_name _;
    
    location / {
        try_files $uri $uri/ =404;
    }
    
    # Добавляем заголовки для отладки
    add_header X-Server "VM2" always;
    add_header X-VPN-IP "{{ vpn_client_ip }}" always;
}

