#!/bin/bash
# Настройка iptables для шлюза

# Очистка старых правил
iptables -t nat -F
iptables -F FORWARD

# NAT для выхода в интернет
iptables -t nat -A POSTROUTING -s {{ vpn_network }} -o eth0 -j MASQUERADE

# Проброс порта 446 -> VM2:443
iptables -t nat -A PREROUTING -i eth0 -p tcp --dport 446 -j DNAT --to-destination {{ vpn_client_ip }}:443

# Разрешить форвардинг для VPN
iptables -A FORWARD -i tun0 -o eth0 -j ACCEPT
iptables -A FORWARD -i eth0 -o tun0 -m state --state ESTABLISHED,RELATED -j ACCEPT
iptables -A FORWARD -p tcp -d {{ vpn_client_ip }} --dport 443 -j ACCEPT

# Сохранение правил
iptables-save > /etc/iptables/rules.v4
