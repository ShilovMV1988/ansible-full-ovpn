#cloud-config

runcmd:
  # Создаем директорию .ssh, если её нет
  - mkdir -p /home/max/.ssh
  
  # Добавляем публичный ключ в authorized_keys
  - echo ""ssh-rsa  mshilov@acer >> /home/max/.ssh/authorized_keys
  
  # Устанавливаем правильные права
  - chmod 700 /home/max/.ssh
  - chmod 600 /home/max/.ssh/authorized_keys
  
  # Меняем владельца (если пользователь max уже существует или будет создан)
  - chown -R max:max /home/max/.ssh
